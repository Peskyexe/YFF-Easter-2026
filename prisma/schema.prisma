// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "sqlite"
  url = env("DATABASE_URL")
}

model Order {
  id              Int      @id @default(autoincrement())
  cost            Int
  user_name       String
  user_address    String
  user_post_nbmr  String
  user_post_area  String
  user_email      String
  user_phone      String
  order_date      String
  dates           String
  tickets         Ticket[]
}

model Ticket {
  id       Int    @id @default(autoincrement())
  type     String  // voksen, barn, ungdom
  quantity Int
  orderId  Int
  order    Order  @relation(fields: [orderId], references: [id])
}
